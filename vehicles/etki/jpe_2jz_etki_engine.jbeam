{
"jpe_2jz_etki_engine": {
    "information":{
        "authors":"Jefe/JPE",
        "name":"3.0L Shinsei 2SZ-GTE Engine",
        "value":3500,
    },
    "slotType" : "etki_engine",
    "slots": [
        ["type", "default", "description"],
        ["etki_jpe_2jz_bottom_end","etki_jpe_2jz_bottom_end", "Engine Bottom End", {"coreSlot":true}],
        ["etki_jpe_2jz_top_end","etki_jpe_2jz_top_end", "Engine Top End", {"coreSlot":true}],
        ["n2o_system","", "Nitrous Oxide System"],
        ["etki_transmission","etki_transmission_5M", "Transmission"],
    ],
    "powertrain": [
        ["type", "name", "inputName", "inputIndex"],
        ["combustionEngine_Icy", "mainEngine", "dummy", 0],
    ],
    "mainEngine": {
        "torque":[
            ["rpm", "torque"],
			[0, 0],
			[500, 150],
			[1000, 190],
			[1500, 205],
			[2000, 225],
			[2500, 230],
			[3000, 242],
			[3500, 252],
			[4000, 260],
			[4500, 265],   
			[5000, 263],
			[5500, 258],
			[6000, 248],
			[6500, 235],
			[7000, 215],
			[7300, 200],
			[8000, 180],
			[8300, 160],			
			[9000, 130],			
			[10000, 100],			
        ],
        "idleRPM":850,		
        "inertia":0.18,
        "friction":12,
        "dynamicFriction":0.020,
        "engineBrakeTorque":44,
        "burnEfficiency":[
            [0, 0.14],
            [0.05, 0.33],
            [0.4, 0.51],
            [0.7, 0.44],
            [1, 0.32],
        ],
        //fuel system
        "energyStorage": ["mainTank","auxTank"],
        "requiredEnergyType":"gasoline",

        //exhaust
        "instantAfterFireSound": "event:>Vehicle>Afterfire>i5_01>single",
        "sustainedAfterFireSound": "event:>Vehicle>Afterfire>i5_01>multi",
        "shiftAfterFireSound": "event:>Vehicle>Afterfire>i5_01>shift",
        "particulates":0.015,
        "afterFireAudibleThresholdInstant": 5000,
        "instantAfterFireCoef": 1.0,
        "instantAfterFireVolumeCoef": 1.75,
        "afterFireAudibleThresholdShift": 5000,
        "shiftAfterFireVolumeCoef": 2.0,
        "afterFireAudibleThresholdSustained": 7000,
        "sustainedAfterFireCoef": 0.9,
        "sustainedAfterFireTime": 0.8,
        "sustainedAfterFireVolumeCoef": 0.85,	

        //cooling and oil system
        "thermalsEnabled":true,
        "engineBlockMaterial":"iron",
        "oilVolume":7,
        "engineBlockAirCoolingEfficiency":35,

        //engine durability
		"torqueReactionNodes:":["e3r","e4r","e2l"],
        "cylinderWallTemperatureDamageThreshold":150,
        "headGasketDamageThreshold":1500000,
        "pistonRingDamageThreshold":1500000,
        "connectingRodDamageThreshold":2000000,
        "maxTorqueRating": 450,
        "maxOverTorqueDamage": 350,
        "maxRPM":7300,
        "maxPhysicalRPM":7350,
        "redlineTorqueDropOffRange": 250

        //node beam interface
        "torqueReactionNodes:":["e1l","e2l","e4r"],
        "waterDamage": {"[engineGroup]:":["engine_intake"]},
        "radiator": {"[engineGroup]:":["radiator"]},
        "engineBlock": {"[engineGroup]:":["engine_block"]},
        "breakTriggerBeam":"engine",
        "uiName":"Engine",
        "soundConfig": "soundConfig",
        "soundConfigExhaust": "soundConfigExhaust",

        //starter motor
        "starterSample":"event:>Engine>Starter>i4_1996_eng",
        "starterSampleExhaust":"event:>Engine>Starter>i4_1996_exh",
        "shutOffSampleEngine":"event:>Engine>Shutoff>i4_1996_eng",
        "shutOffSampleExhaust":"event:>Engine>Shutoff>i4_1996_exh",
		"starterVolume":0.78,
		"starterVolumeExhaust":0.68,
		"shutOffVolumeEngine":0.72,
		"shutOffVolumeExhaust":0.70,

		"idleRPMStartRate":1.2,
		"idleRPMStartCoef":1.6,
		"idleRPMFallRate":0.6

        //engine deform groups
        "deformGroups":["mainEngine", "mainEngine_intake", "mainEngine_accessories"]
        "deformGroups_oilPan":["oilpan_damage"]
    },
	"soundConfig":{
		"sampleName":"I6_2_engine",
		"fundamentalFrequencyCylinderCount":6,

    "mainGain":1.975,
    "onLoadGain":0.98,
    "offLoadGain":0.80,

		"eqLowFreq":120,
		"eqLowGain":9,
		"eqLowWidth":0.7,

		"eqHighFreq":4200,
		"eqHighGain":5.5,
		"eqHighWidth":0.6,

		"lowShelfFreq":90,
		"lowShelfGain":4,

		"highShelfFreq":5200,
		"highShelfGain":7,

	},
	"soundConfigExhaust":{
		"sampleName":"I6_2_exhaust",
		"fundamentalFrequencyCylinderCount":6,

    "mainGain":2.95,
    "onLoadGain":1.05,
    "offLoadGain":0.72,

		"eqLowFreq":110,
		"eqLowGain":8,
		"eqLowWidth":0.6,

		"eqHighFreq":4800,
		"eqHighGain":5,
		"eqHighWidth":0.7,

		"lowShelfFreq":95,
		"lowShelfGain":6,

		"highShelfFreq":4500,
		"highShelfGain":6,

	},
    "vehicleController": {
        "clutchLaunchStartRPM":1500,
        "clutchLaunchTargetRPM":2000,
        //**highShiftDown can be overwritten by automatic transmissions**
        "highShiftDownRPM":[0,0,0,2800,3800,4300,4700,4700],
        //**highShiftUp can be overwritten by intake modifications**
        "highShiftUpRPM":6800,
    },	
    "flexbodies": [
