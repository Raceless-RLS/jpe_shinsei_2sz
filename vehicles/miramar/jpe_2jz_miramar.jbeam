        ["rpmspin"  , "miramar_jpe_2jz_pulley_5", "e2r","e2l","e4r",  {"x":3, "y":0, "z":0}, {"x":0, "y":1, "z":0}    , {"x":0, "y":0, "z":0}, -360, 360, 0, 1],
        ["rpmspin"  , "miramar_jpe_2jz_pulley_6", "e2r","e2l","e4r",  {"x":3, "y":0, "z":0}, {"x":0, "y":1, "z":0}    , {"x":0, "y":0, "z":0}, -360, 360, 0, 1],
